# Copy to .env and fill in. The .env file stays on your machine / VPS — never commit it.

# Required: your Anthropic API key (the proxy holds this; the browser never sees it).
ANTHROPIC_API_KEY=sk-ant-...

# Access control is handled by your reverse proxy (e.g. Caddy basic_auth), not the app.

# Models. Defaults match the keep-asking trial family.
MODEL=claude-sonnet-4-6
FAST_MODEL=claude-haiku-4-5

# Guards (sensible defaults; tune as you like).
PORT=8080
MAX_REQUESTS_PER_DAY=100      # per visitor IP
DAILY_TOKEN_CAP=2000000       # hard global ceiling on output tokens/day; calls 503 once hit
MAX_INPUT_CHARS=60000         # reject oversized pasted/parsed source text
